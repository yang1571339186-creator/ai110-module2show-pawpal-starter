classDiagram
    %% PawPal+ System Design - Redesigned
    %% A pet care planning assistant that generates daily schedules with time-based reasoning

    %% =====================
    %% ENUMERATIONS
    %% =====================
    class PriorityLevel {
        <<enumeration>>
        LOW = 1
        MEDIUM = 2
        HIGH = 3
    }


    %% =====================
    %% CORE ENTITIES
    %% =====================
    class TimeSlot {
        -start_time: str
        -end_time: str
        +parse(time_string: str) TimeSlot$
        +duration_minutes() int
        +conflicts_with(other: TimeSlot) bool
    }

    class Owner {
        -name: str
        -available_time_slots: List~TimeSlot~
        -tasks: List~Task~
        +get_name() str
        +set_name(name: str) void
        +get_available_time_slots() List~TimeSlot~
        +set_available_time_slots(slots: List~TimeSlot~) void
        +get_tasks() List~Task~
        +set_tasks(tasks: List~Task~) void
        +add_task(task: Task) void
        +remove_task(task: Task) void
        +total_available_minutes() int
        +__repr__() str
    }

    class Pet {
        -name: str
        -species: str
        -owner: Owner
        +get_name() str
        +set_name(name: str) void
        +get_species() str
        +set_species(species: str) void
        +get_owner() Owner
        +set_owner(owner: Owner) void
        +__repr__() str
    }

    class Task {
        -name: str
        -pets: List~Pet~
        -duration_minutes: int
        -priority: PriorityLevel
        -is_recurring: bool
        -completed: bool
        -notes: str
        +get_name() str
        +set_name(name: str) void
        +get_pets() List~Pet~
        +set_pets(pets: List~Pet~) void
        +get_duration_minutes() int
        +set_duration_minutes(duration: int) void
        +get_priority() PriorityLevel
        +set_priority(priority: PriorityLevel) void
        +get_is_recurring() bool
        +set_is_recurring(is_recurring: bool) void
        +get_completed() bool
        +set_completed(completed: bool) void
        +get_notes() str
        +set_notes(notes: str) void
        +__repr__() str
    }

    class Scheduler {
        +sort_tasks_by_priority(tasks: List~Task~) List~Task~$
        +filter_tasks_by_time(tasks: List~Task~, available_minutes: int) List~Task~$
        +create_daily_schedule(owner: Owner, tasks: List~Task~) Map~TimeSlot, List~Task~~$
        +explain_choice(task: Task, reason: str) str$
    }

    %% =====================
    %% RELATIONSHIPS
    %% =====================
    Owner "1" o-- "*" Pet : owns
    Owner "1" o-- "*" Task : creates
    Owner "1" *-- "*" TimeSlot : available_time_slots

    Pet "*" --o "1" Task : applies_to

    Task "1" -- "1" PriorityLevel : has

    Scheduler ..> TimeSlot : schedules into
    Scheduler ..> Task : schedules
